# Required — backend API base (no trailing slash)
NEXT_PUBLIC_API_URL="https://api.snookalook.com/v1"

# Required — auth mode in production (backend = HttpOnly cookie + proxy)
NEXT_PUBLIC_AUTH_MODE="backend"

# Required — WebSocket base for realtime
NEXT_PUBLIC_WS_URL="wss://api.snookalook.com"

# Required — Doctrine 8.11: stable Server Action encryption key across deploys
# Generate: openssl rand -base64 32
# Rotate only on key compromise.
SERVER_ACTIONS_ENCRYPTION_KEY="<generate-with-openssl-rand-base64-32>"

# Required for supabase auth mode (leave blank if AUTH_MODE=backend)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Build-time — Sentry source map upload (set in Vercel env, not committed)
SENTRY_ORG="<your-sentry-org>"
SENTRY_AUTH_TOKEN="<sentry-auth-token>"

# Dev-only — ignored in production (getRuntimeAuthMode rejects dev mode in prod)
# NEXT_PUBLIC_AUTH_MODE="dev"
# NEXT_PUBLIC_DEV_USER_ID="<uuid>"
